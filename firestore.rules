rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 Temporary open rule until Sept 21, 2025
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2025, 9, 21);
    }

    // ✅ Allow read/write to contacts (publicly)
    match /contacts/{docId} {
      allow read, write: if true;
    }

    // ✅ Alternative secure form submission rule
    // You can uncomment this if you want form-only submission and no reads:
    /*
    match /contacts/{docId} {
      allow create: if true;
      allow read: if false;
    }
    */

    // ✅ Completely open rules (not recommended for production)
    /*
    match /{document=**} {
      allow read, write: if true;
    }
    */
  }
}
